{
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",

    "moduleResolution": "bundler",

    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "dist",

    "resolveJsonModule": true,
    "jsx": "react-jsx",

    "strict": false,

    "types": ["node"],

    "paths": {
      "@/*": ["./src/renderer/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".webpack"]
}
